# ==============================================================================
# AI20K Project — Unified Environment Variables (.env.example)
# ==============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to git!
#
# TO SWITCH BETWEEN ENVIRONMENT CONFIGURATIONS:
# - Local Dev: Set COMPOSE_PROFILES=dev and APP_DATA_VOLUME=./data
# - Production: Set COMPOSE_PROFILES= and APP_DATA_VOLUME=app_data
# ==============================================================================

# ---- Docker Compose Configuration ----
# Set to 'dev' to automatically launch the PostgreSQL container in local development.
# Leave blank in production to use external databases (like AWS RDS).
COMPOSE_PROFILES=dev

# Volume source for /app/data. Use './data' for local dev bind mount, 'app_data' for production docker volume.
APP_DATA_VOLUME=./data

# ---- Application Environment ----
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=INFO

# ---- LLM Configuration ----
OPENAI_API_KEY=sk-your-key-here
MODEL_NAME=gpt-4o-mini
LLM_TEMPERATURE=0.2
# Claude is used by the Markdown schema/example pipeline when configured.
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-6

# ---- Database ----
# In Dev (Local Docker):
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=c2_app_065
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:replace-with-a-strong-password@localhost:5432/c2_app_065
DATABASE_CONNECT_RETRIES=5
DATABASE_CONNECT_RETRY_SECONDS=1.0
DATABASE_ALLOW_SQLITE_FALLBACK=false

# In Production (AWS RDS Example):
# DATABASE_URL=postgresql://db_user:db_password@your-rds-endpoint.ap-southeast-1.rds.amazonaws.com:5432/c2_app_065
# DATABASE_CONNECT_RETRIES=20
# DATABASE_CONNECT_RETRY_SECONDS=2

# ---- URLs & CORS ----
# Local Development defaults:
CORS_ORIGINS=http://localhost:8000,http://localhost:3000,http://localhost:5173
FRONTEND_URL=http://localhost:8000

# Production defaults:
# CORS_ORIGINS=https://your-domain.example.com
# FRONTEND_URL=https://your-domain.example.com

# ---- Auth ----
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
# Comma-separated emails that should receive admin permission.
ADMIN_EMAILS=admin@example.com

# ---- Email Verification ----
# If SMTP_HOST is empty, verification links are printed in the API logs for local development.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_USE_TLS=true
EMAIL_VERIFICATION_URL_BASE=http://localhost:8000/api/v1/auth/verify-email
# Production example:
# EMAIL_VERIFICATION_URL_BASE=https://your-domain.example.com/api/v1/auth/verify-email

# ---- LangSmith (AI Logs — Deliverable #4) ----
# LANGCHAIN_API_KEY=your-langsmith-key-here
# LANGCHAIN_PROJECT=ai20k-agent
# LANGCHAIN_TRACING_V2=true

# ---- AI Hook Logging (provided by instructor) ----
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=replace-with-ai-log-api-key
AI_LOG_DIR=.ai-log
